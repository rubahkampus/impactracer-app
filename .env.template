# ==========================================================================
# ImpacTracer v4.0 - Environment Configuration
# Copy this file to .env and fill in the required fields.
# ==========================================================================

# REQUIRED: Gemini API Key (obtain from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# LLM model selection (Gemini 2.5 family recommended)
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-2.5-flash-lite
# LLM_MODEL=gemini-2.5-flash
# LLM_TEMPERATURE=0.0
# LLM_SEED=42

# Embedding and reranking models (local inference)
# EMBEDDING_MODEL=BAAI/bge-m3
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# EMBEDDING_BATCH_SIZE=32

# Storage paths
# DB_PATH=./data/impactracer.db
# CHROMA_PATH=./data/chroma_store

# Indexer calibration
# TOP_K_TRACEABILITY=5
# MIN_TRACEABILITY_SIMILARITY=0.60
# DEGENERATE_EMBED_MIN_LENGTH=50

# Retrieval and reranking
# MAX_CANDIDATES_PER_QUERY=15
# MAX_CANDIDATES_POST_RRF=15
# MAX_CANDIDATES_POST_RERANK=15
# RRF_K=60
# MIN_RERANKER_SCORE_FOR_VALIDATION=0.01

# Plausibility gate (FR-C4)
# PLAUSIBILITY_GATE_DENSITY_THRESHOLD=0.35
# PLAUSIBILITY_GATE_MAX_PER_FILE=2

# BFS
# BFS_GLOBAL_MAX_DEPTH=3
# BFS_HIGH_CONF_TOP_N=5

# Context window budget
# LLM_MAX_CONTEXT_TOKENS=100000
